{
  "grammars": [
    {
      "name": "zutai",
      "camelcase": "Zutai",
      "scope": "source.zutai",
      "path": ".",
      "file-types": [
        "zt"
      ]
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "Tree-sitter grammar for Zutai general mode (.zt)",
    "links": {
      "repository": "https://github.com/tree-sitter/tree-sitter-zutai"
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true
  }
}
